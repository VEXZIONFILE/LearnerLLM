{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "learnerlm-api",
  "main": "src/worker.py",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": [
    "python_workers",
    "python_dedicated_snapshot"
  ],
  "vars": {
    "APP_NAME": "LearnerLM API",
    "CORS_ORIGINS": "*",
    "OPENROUTER_BASE_URL": "https://openrouter.ai/api/v1",
    "OPENROUTER_REFERER": "https://github.com/VEXZIONFILE/LearnerLLM",
    "OPENROUTER_TITLE": "LearnerLM",
    "GOOGLE_PLAY_PACKAGE_NAME": "com.learnerlm",
    "BILLING_VERIFICATION_DISABLED": "true",
    "FIREBASE_AUTH_DISABLED": "false",
    "FREE_DAILY_SCAN_LIMIT": "3",
    "DEV_AUTH_UID": "dev-user"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "learnerlm",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ],
  "observability": {
    "enabled": true
  }
}
