# LearnerLM API
APP_NAME=LearnerLM API
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./data/learnerlm.db
CORS_ORIGINS=*

# OpenRouter (server-side only — never ship to the Android app)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/VEXZIONFILE/LearnerLLM
OPENROUTER_TITLE=LearnerLM

# Firebase Admin — path to service account JSON from Firebase Console
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
# Fly.io / Docker: paste full JSON as a secret instead of a file path
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# Set true for local dev without Firebase (use Authorization: Bearer dev)
FIREBASE_AUTH_DISABLED=true
DEV_AUTH_UID=dev-user

# Google Play billing
GOOGLE_PLAY_PACKAGE_NAME=com.learnerlm
GOOGLE_PLAY_CREDENTIALS_PATH=
# When true, accepts purchase tokens without calling Google Play API (dev only)
BILLING_VERIFICATION_DISABLED=true

FREE_DAILY_SCAN_LIMIT=3
